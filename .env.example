# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── LLM APIs ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here    # optional — Groq is used by default

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=docsight-rag

# ── Data Sources ──────────────────────────────────────────────────────────────
ENTREZ_EMAIL=your@email.com
SEC_EDGAR_NAME=Your Name
SEC_EDGAR_EMAIL=your@email.com

# ── Inference Backend ─────────────────────────────────────────────────────────
# "ollama" = local fine-tuned models via Ollama
# "groq"   = Groq API with base models (no fine-tuning required)
# "hf"     = local HuggingFace Transformers (PyTorch)
LLM_BACKEND=groq
# Optional per-agent overrides (defaults to LLM_BACKEND)
# ROUTER_BACKEND=groq
# EXPERT_BACKEND=ollama
# SYNTH_BACKEND=ollama
# WEB_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── HuggingFace Transformers (optional) ─────────────────────────────────────
# HF_ROUTER_MODEL=path_or_hf_id
# HF_FINANCE_MODEL=path_or_hf_id
# HF_MEDICAL_MODEL=path_or_hf_id
# HF_SYNTH_MODEL=path_or_hf_id
# HF_WEB_MODEL=path_or_hf_id
# HF_DEVICE_MAP=auto
# HF_DTYPE=auto
# HF_TRUST_REMOTE_CODE=false
